#!/usr/bin/env bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

OUT_DIR="$DIR/command"
OUT_FILE="$OUT_DIR/jarvis"
BUILD_TIME="$(date +'%d-%m-%Y at %I:%M:%S %p')"

mkdir -p "$OUT_DIR"

{
    echo "#!/usr/bin/env bash"
    echo
    echo "# AUTO-GENERATED by build.sh -- do not edit directly."
    echo "# Built on: $BUILD_TIME"
    echo "# Edit files in src/ and run ./build.sh to rebuild."
    echo
    echo "set -euo pipefail"
    echo

    cat "$DIR/src/core/header.sh"
    echo
    cat "$DIR/src/core/globals.sh"
    echo
    cat "$DIR/src/core/helpers.sh"
    echo

    for file in "$DIR"/src/cmd/*.sh; do
        cat "$file"
        echo
    done

    cat "$DIR/src/core/main.sh"
    echo

    echo 'main "$@"'

} > "$OUT_FILE"

chmod +x "$OUT_FILE"

echo "
🟆  Build Complete!  🟆

===============================================================================
⫸ File:       $OUT_FILE
⫸ Inserted:   ($(wc -l < "$OUT_FILE") lines)
⫸ At:         $BUILD_TIME
===============================================================================

🟆  You can PUSH now  🟆
"
