# ── Help ────────────────────────────────────────────────────────────────────
show_help() {
    cat << EOF
${script_name} v${version} - Oooga Booga Buga

Usage: ${script_name} <command>

Available commands:
    hello                   Display hello world message
    attendance-sheet        Create this month's attendance sheet
    help                    Show this help message

Examples:
    ${script_name} hello
    ${script_name} hi Sakif
    ${script_name} attendance-sheet
    ${script_name} help
EOF
}


# =================================================================================
# == Execution ====================================================================
# =================================================================================
case "$1" in
    attendance-sheet)
        echo "This month's attendance sheet has been created."
        ;;

    version|v|--version|-v)
        echo "${script_name} v${version}"
        ;;

    help|h|--help|-h)
        show_help
        ;;

    *)
        echo "Unknown command. Type: '${script_name} --help' for usage."
        ;;
esac
