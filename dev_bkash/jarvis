# ── Math helpers ──────────────────────────────────────────────────────────────

_bkash_calc() {
    # $1 = awk expression   returns: computed value rounded to 2 decimal places
    awk "BEGIN { printf \"%.2f\", $1 }"
}

_bkash_get_sendmoney_fee() {
    local amount="$1"
    # Send money fee slabs (fixed, not percentage)
    # 0 – 50        → 0 BDT
    # 50.01 – 25000 → 5 BDT
    # 25000+        → 10 BDT
    awk -v a="$amount" 'BEGIN {
        if (a <= 50)    print "0.00"
        else if (a <= 25000) print "5.00"
        else            print "10.00"
    }'
}

