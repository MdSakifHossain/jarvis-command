#!/usr/bin/env bash

set -euo pipefail

# ── Identity ──────────────────────────────────────────────────────────────────
script_name="$(basename "$0")"
small_desc="Personal CLI Tool"
version="1.6.0"

# ── Colors ────────────────────────────────────────────────────────────────────
RESET='\033[0m'
