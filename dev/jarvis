show_banner() {
    current_width=$(tput cols 2> /dev/null || echo 80) # Get current terminal width
    cutoff_width=60                                    # Define what counts as "small"

    is_small=false
    if [ "$current_width" -lt "$cutoff_width" ]; then
        is_small=true
    fi

    if $is_small; then
        show_banner_1
    else
        show_banner_2
    fi

    log_txt_dm "  Type \"${script_name} --help\" for more details."

    if $is_small; then
        divider_small
    else
        show_divider
    fi

    echo
}

refresh_banner() {
    clear
    show_banner
}

# ── Help ────────────────────────────────────────────────────────────────────
show_help() {
    cat << EOF
${script_name} - ${small_desc}

Usage:

    ${script_name} [command]
    ${script_name} [flags]

Available commands:

    lights, lock, unlock, observe, monitor,
    tree, power, version, help

Flags:

    -v, --version   Show Version Info
    -h, --help      Show Help

For more info, Run:

    ${script_name} <command> --help


EOF
}

show_light_help() {
    local cmd_name="lights"

    cat << EOF
Change Color of RAM LED

Usage:

    ${script_name} ${cmd_name} [Command]
    ${script_name} ${cmd_name} [Flags]

Available Commands:

    on        Turn on RAM LED
    off       Turn off RAM LED
    help      Show Help

Flags:

    -h,       Show Help
    --help    Show Help

EOF
}

# ── Subcommand: lights ───────────────────────────────────────────────────────
cmd_lights() {
    local cmd_name="lights"

    case "$@" in
        -h | --help | h | help)
            show_light_help
            ;;
        on | 1)
            lights_on_helper
            ;;
        off | 0)
            lights_off_helper
            ;;
        *)
            show_light_help
            ;;
    esac
}

# ── Subcommand: lock ─────────────────────────────────────────────────────────
cmd_lock() {
    require_ubuntu
    echo
    delay_min="${1:-}"
    if [[ -n "$delay_min" && ! "$delay_min" =~ ^[0-9]+$ ]]; then
        log_fail "Delay must be a number (minutes)."
        exit 1
    fi

    if [[ -n "$delay_min" && "$delay_min" -gt 0 ]]; then
        log_info "Lock scheduled in ${BORANGE}${delay_min}${RESET} minute(s)..."

        (
            sleep "$((delay_min * 60))"
            lock_helper
        ) > /dev/null 2>&1 &
        disown

    else
        log_info "Initializing command..."
        log_info "Locking Screen..."
        lock_helper
        log_info "Command finished successfully"
    fi

    echo
}

# ── Subcommand: unlock ───────────────────────────────────────────────────────
cmd_unlock() {
    require_ubuntu
    echo
    log_info "Initializing command..."
    log_info "Unlocking Screen..."
    unlock_helper
    log_info "Command finished successfully"
    echo
}

# =================================================================================
# == Execution ====================================================================
# =================================================================================
case "${1:-}" in
    v | -v | version | --version)
        show_version
        exit 0
        ;;
    h | -h | help | --help)
        show_help
        exit 0
        ;;
esac

SUBCOMMAND="${1:-}"
shift || true

case "$SUBCOMMAND" in
    light | lights | ram | rams | led | leds | lt | lts)
        cmd_lights "$@"
        exit 0
        ;;
    lock)
        cmd_lock "$@"
        exit 0
        ;;
    unlock)
        cmd_unlock
        exit 0
        ;;
    observe | monitor)
        refresh_banner
        tail -f "$HOME/.local/logs/vault-observer.log"
        ;;
    poweroff | power | pwr | shutdown)
        sudo shutdown now
        ;;
    tree | list | lst | ls)
        require_cmd tree
        tree --gitignore --dirsfirst
        exit 0
        ;;
    *)
        show_help
        exit 0
        ;;
esac
