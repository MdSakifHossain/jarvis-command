check_internet() {
    require_apt_package curl
    if ! curl -s --max-time 5 https://google.com > /dev/null; then
        log_fail "No internet connection."
        return 1
    fi

    log_ok "Internet connection active"
}

ensure_dir() {
    local path="$1"
    if [[ ! -d "$path" ]]; then
        mkdir -p "$path"
        log_ok "Created directory: $path"
    fi
}

show_version() {
    log_txt_nm "${script_name} v${version}"
}

lock_helper() {
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call --print-reply \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.Lock \
        > /dev/null 2>&1
}

unlock_helper() {
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call --print-reply \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.SetActive boolean:false \
        > /dev/null 2>&1
}

lights_on_helper() {
    require_openrgb
    echo
    log_info "Turning lights ON..."
    openrgb --mode static --color ffffff > /dev/null 2>&1
    log_info "Command execution Completed"
    echo
}

lights_off_helper() {
    require_openrgb
    echo
    log_info "Turning lights OFF..."
    openrgb --mode static --color 000000 > /dev/null 2>&1
    log_info "Command execution Completed"
    echo
}

