    log_txt_nm "Unknown command.\nType \"${script_name} --help\" for more details."
}

show_version() {
    log_txt_nm "${script_name} v${version}"
}

lock_helper() {
    # here i redirected output to silence
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call --print-reply \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.Lock \
        >/dev/null 2>&1
}

unlock_helper() {
    # here i just removed the "--print-reply" from the send lines last portion
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.SetActive boolean:false
}

