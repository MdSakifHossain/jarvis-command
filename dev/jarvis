show_banner() {
  current_width=$(tput cols 2>/dev/null || echo 80) # Get current terminal width
  cutoff_width=60 # Define what counts as "small"

  is_small=false
  if [ "$current_width" -lt "$cutoff_width" ]; then
    is_small=true
  fi

  if $is_small; then
    show_banner_1
  else
    show_banner_2
  fi

  log_txt_dm "  Type \"${script_name} --help\" for more details.";

  if $is_small; then
    divider_small
  else
    show_divider
  fi

  echo
}

refresh_banner() {
    clear
    show_banner
}

# в”Җв”Җ Help в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
show_help() {
    cat << EOF
${script_name} - ${small_desc}

Usage:

    ${script_name} [command]
    ${script_name} [flags]

Available commands:

    lights, lock, unlock, version, help

Flags:

    -v, --version   Show Version Info
    -h, --help      Show Help

EOF
}


# =================================================================================
# == Execution ====================================================================
# =================================================================================
case "${1:-}" in
    v|-v|version|--version)   clear;  show_version;  exit 0 ;;
    h|-h|help|--help)         clear;  show_help;     exit 0 ;;
esac

SUBCOMMAND="${1:-}"
shift || true

case "$SUBCOMMAND" in
    lt|lts|light|lights|ram|rams|led|leds)    echo "lights";      exit 0 ;;
    lock)                                     echo "lock";        exit 0 ;;
    unlock)                                   echo "unlock";      exit 0 ;;
    *)                                        clear;  show_help;  exit 0 ;;
esac
