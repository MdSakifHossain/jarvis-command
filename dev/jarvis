# ── Color helpers ─────────────────────────────────────────────────────────────
log_clr_l1() { echo -e "${ORANGE}${1}${RESET}"; }
log_clr_l2() { echo -e "${BORANGE}${1}${RESET}"; }
log_clr_l3() { echo -e "${DIM_ORANGE}${1}${RESET}"; }

# ── Text helpers ──────────────────────────────────────────────────────────────
log_txt_nm() { echo -e "${1}"; }
log_txt_bd() { echo -e "${BOLD}${1}${RESET}"; }
log_txt_dm() { echo -e "${DIM}${1}${RESET}"; }

# ── Semantic logging ──────────────────────────────────────────────────────────
log_info() { log_txt_nm "${BLUE}[INFO]${RESET} $*"; }
log_ok() { echo -e "  ${BGREEN}✔${RESET}  $*"; }
log_warn() { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
log_fail() {
    log_txt_nm "${RED}[ERROR]${RESET} $* \n" >&2
    exit 1
}
log_label() { echo -e "  ${BORANGE}▸${RESET}  ${BWHITE}$*${RESET}"; }

# ── UI helpers ────────────────────────────────────────────────────────────────
show_divider() { log_clr_l3 "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"; }
divider_small() { log_clr_l3 "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"; }

# ── Helpers ───────────────────────────────────────────────────────────────────
require_ubuntu() {
    source /etc/os-release

    if [[ "$ID" != "ubuntu" ]]; then
        echo
        log_fail "This script currently supports Ubuntu only."
    fi
}

require_cmd() {
    local cmd="$1"
    local pkg="${2:-$1}"

    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo
        log_fail "Missing dependency: $cmd

Install it using:
    sudo apt install $pkg"
    fi
}

show_version() {
    log_txt_nm "${script_name} v${version}"
}

lock_helper() {
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call --print-reply \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.Lock \
        > /dev/null 2>&1
}

unlock_helper() {
    dbus-send --session --dest=org.gnome.ScreenSaver \
        --type=method_call --print-reply \
        /org/gnome/ScreenSaver \
        org.gnome.ScreenSaver.SetActive boolean:false \
        > /dev/null 2>&1
}

lights_on_helper() {
    echo
    log_info "Turning lights ON..."
    openrgb --mode static --color ffffff > /dev/null 2>&1
    log_info "Command execution Completed"
    echo
}

lights_off_helper() {
    echo
    log_info "Turning lights OFF..."
    openrgb --mode static --color 000000 > /dev/null 2>&1
    log_info "Command execution Completed"
    echo
}

