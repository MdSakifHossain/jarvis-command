#!/usr/bin/env bash

# =============================================================================
# Personal Command Line Tool
# =============================================================================

# ── Identity ──────────────────────────────────────────────────────────────────
script_name="$(basename "$0")"
version="0.5"

# ── Colors ────────────────────────────────────────────────────────────────────
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
ORANGE='\033[38;5;209m'
BORANGE='\033[1;38;5;209m'
DIM_ORANGE='\033[2;38;5;209m'

# ── Color helpers ─────────────────────────────────────────────────────────────
log_clr_l1() { echo -e "${ORANGE}${1}${RESET}"; }
log_clr_l2() { echo -e "${BORANGE}${1}${RESET}"; }
log_clr_l3() { echo -e "${DIM_ORANGE}${1}${RESET}"; }

# ── Text helpers ──────────────────────────────────────────────────────────────
log_txt_nm() { echo -e "${1}"; }
log_txt_bd() { echo -e "${BOLD}${1}${RESET}"; }
log_txt_dm() { echo -e "${DIM}${1}${RESET}"; }

# ── UI helpers ────────────────────────────────────────────────────────────────
divider()  { log_clr_l3 "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"; }

# ── helpers ───────────────────────────────────────────────────────────────────

show_final_error() {
    log_txt_nm "Unknown command. Type: '${script_name} --help' for usage."
}

