show_banner() {
  current_width=$(tput cols 2>/dev/null || echo 80) # Get current terminal width
  cutoff_width=60 # Define what counts as "small"

  is_small=false
  if [ "$current_width" -lt "$cutoff_width" ]; then
    is_small=true
  fi

  if $is_small; then
    show_banner_1
  else
    show_banner_2
  fi

  log_txt_dm "  Type: '${script_name} --help' for Help";

  if $is_small; then
    divider_small
  else
    show_divider
  fi

  echo
}

# ── Help ────────────────────────────────────────────────────────────────────
show_help() {
    cat << EOF
${script_name} - ${small_desc}

Usage: ${script_name} <command>

Available commands:
    attendance-sheet        Create this month's attendance sheet
    lights                  Turns RAM LED lights On/Off
    screen                  Lock/Unlocks Screen
    version                 Show Version
    help                    Show Help

Examples:
    ${script_name} attendance-sheet
    ${script_name} <lt|lts|light|lights|ram|rams> <on|off|1|0>
    ${script_name} screen <lock|unlock>
    ${script_name} version
    ${script_name} help
EOF
}


# =================================================================================
# == Execution ====================================================================
# =================================================================================
case "$1" in
    attendance-sheet)
        log_txt_nm "This month's attendance sheet has been created."
        ;;

    lt|lts|light|lights|ram|rams)
        # openrgb --mode off;

        case "$2" in
            on|1)
                log_txt_nm "[INFO] Turning lights ON..."
                openrgb --color FFFFFF
                log_txt_nm "[INFO] Command execution Completed"
                ;;

            off|0)
                log_txt_nm "[INFO] Turning lights OFF..."
                openrgb --mode off
                log_txt_nm "[INFO] Command execution Completed"
                ;;

            *)
                log_txt_nm "[Error]: Unknown lights command."
                show_final_error
                ;;
        esac

        ;;

    screen)
        case "$2" in
            lock)
                delay_min="$3"

                if [[ -n "$delay_min" && ! "$delay_min" =~ ^[0-9]+$ ]]; then
                    log_txt_nm "[Error]: Delay must be a number (minutes)."
                    exit 1
                fi

                if [[ -n "$delay_min" && "$delay_min" -gt 0 ]]; then
                    log_txt_nm "[INFO] Lock scheduled in ${delay_min} minute(s)..."

                    (
                        sleep "$((delay_min * 60))"
                        dbus-send --session --dest=org.gnome.ScreenSaver \
                            --type=method_call --print-reply \
                            /org/gnome/ScreenSaver \
                            org.gnome.ScreenSaver.Lock
                    ) >/dev/null 2>&1 & disown

                else
                    log_txt_nm "[INFO] Locking Screen..."
                    dbus-send --session --dest=org.gnome.ScreenSaver \
                        --type=method_call --print-reply \
                        /org/gnome/ScreenSaver \
                        org.gnome.ScreenSaver.Lock
                    log_txt_nm "[INFO] Command execution Completed"
                fi
                ;;

            unlock)
                log_txt_nm "[INFO] Unlocking Screen..."
                dbus-send --session --dest=org.gnome.ScreenSaver \
                    --type=method_call --print-reply \
                    /org/gnome/ScreenSaver \
                    org.gnome.ScreenSaver.SetActive boolean:false
                log_txt_nm "[INFO] Command execution Completed"
                ;;

            *)
                log_txt_nm "[Error]: Unknown command."
                show_final_error
                ;;
        esac
        ;;

    version|v|--version|-v)
        log_txt_nm "${script_name} v${version}"
        ;;

    help|h|--help|-h)
        show_help
        ;;

    *)
        # show_final_error
        clear
        show_banner
        ;;
esac
